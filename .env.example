# Tu numero de WhatsApp con codigo de pais (ej: 584121234567 para Venezuela)
CALLMEBOT_PHONE=58412XXXXXXX
# Consigue tu APIKEY enviando "I allow callmebot to send me messages" al +34 644 14 44 23 en WhatsApp
CALLMEBOT_APIKEY=tu_apikey_aqui
EBAY_SITE=https://www.ebay.com
MAX_PRECIO=200
INTERVALO_HORAS=8

# Opcional: lista separada por comas
MARCAS=HP,Dell,Lenovo,Asus,Acer,MSI

# Pruebas seguras
DRY_RUN=1
RUN_ONCE=1

# Cuantas ofertas incluir por mensaje
TOP_POR_MENSAJE=3

# Reintentos y pausas entre consultas
MAX_REINTENTOS=3
SLEEP_MIN_SEGUNDOS=3
SLEEP_MAX_SEGUNDOS=6

# Navegador real para evitar el bloqueo de requests
BROWSER_HEADLESS=0
BROWSER_PROFILE_DIR=.browser-profile
BROWSER_TIMEOUT_MS=45000
BROWSER_SETTLE_MS=2500
BROWSER_RESULTS_WAIT_MS=10000

# Opcional: fuerza un navegador concreto
# BROWSER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# BROWSER_CHANNEL=chrome
